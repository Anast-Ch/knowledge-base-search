\u1042\'c2\u1089\'f1\u1105\'b8 \u1101\'fd\u1090\'f2\u1086\'ee \u1085\'ed\u1099\'fb\u1085\'ed\u1077\'e5 \u1086\'ee\u1073\'e1\u1074\'e2\u1077\'e5\u1090\'f2\u1096\'f8\u1072\'e0\u1083\'eb\u1086\'ee,}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1053\'cd\u1077\'e5 \u1079\'e7\u1085\'ed\u1072\'e0\u1102\'fe, \u1087\'ef\u1088\'f0\u1072\'e0\u1074\'e2\u1086\'ee, \u1087\'ef\u1086\'ee\u1095\'f7\u1077\'e5\u1084\'ec\u1091\'f3;}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1044\'c4\u1072\'e0, \u1074\'e2\u1087\'ef\u1088\'f0\u1086\'ee\u1095\'f7\u1077\'e5\u1084\'ec, \u1076\'e4\u1088\'f0\u1091\'f3\u1075\'e3\u1091\'f3 \u1084\'ec\u1086\'ee\u1077\'e5\u1084\'ec\u1091\'f3}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1042\'c2 \u1090\'f2\u1086\'ee\u1084\'ec \u1085\'ed\u1091\'f3\u1078\'e6\u1076\'e4\u1099\'fb \u1073\'e1\u1099\'fb\u1083\'eb\u1086\'ee \u1086\'ee\u1095\'f7\u1077\'e5\u1085\'ed\u1100\'fc \u1084\'ec\u1072\'e0\u1083\'eb\u1086\'ee,}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
