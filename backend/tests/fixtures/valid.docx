\par \pard\plain \s0\qj\fi567\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li0\lin0\ri0\rin0\sb0\sa0\ltrpar

\par \pard\plain \s0\qj\fi567\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li0\lin0\ri0\rin0\sb0\sa0\ltrpar

\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u171\'ab\u1053\'cd\u1077\'e5 \u1089\'f1\u1087\'ef\u1080\'e8\u1090\'f2\u1089\'f1\u1103\'ff, \u1085\'ed\u1103\'ff\u1085\'ed\u1103\'ff: \u1079\'e7\u1076\'e4\u1077\'e5\u1089\'f1\u1100\'fc \u1090\'f2\u1072\'e0\u1082\'ea \u1076\'e4\u1091\'f3\u1096\'f8\u1085\'ed\u1086\'ee!}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1054\'ce\u1090\'f2\u1082\'ea\u1088\'f0\u1086\'ee\u1081\'e9 \u1086\'ee\u1082\'ea\u1085\'ed\u1086\'ee \u1076\'e4\u1072\'e0 \u1089\'f1\u1103\'ff\u1076\'e4\u1100\'fc \u1082\'ea\u1086\'ee \u1084\'ec\u1085\'ed\u1077\'e5\u187\'bb.\~\u8212\'97}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u171\'ab\u1063\'d7\u1090\'f2\u1086\'ee, \u1058\'d2\u1072\'e0\u1085\'ed\u1103\'ff, \u1095\'f7\u1090\'f2\u1086\'ee \u1089\'f1 \u1090\'f2\u1086\'ee\u1073\'e1\u1086\'ee\u1081\'e9?\u187\'bb\~\u8211\'96 \u171\'ab\u1052\'cc\u1085\'ed\u1077\'e5 \u1089\'f1\u1082\'ea\u1091\'f3\u1095\'f7\u1085\'ed\u1086\'ee,}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1055\'cf\u1086\'ee\u1075\'e3\u1086\'ee\u1074\'e2\u1086\'ee\u1088\'f0\u1080\'e8\u1084\'ec \u1086\'ee \u1089\'f1\u1090\'f2\u1072\'e0\u1088\'f0\u1080\'e8\u1085\'ed\u1077\'e5\u187\'bb.\~\u8212\'97}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u171\'ab\u1054\'ce \u1095\'f7\u1077\'e5\u1084\'ec \u1078\'e6\u1077\'e5, \u1058\'d2\u1072\'e0\u1085\'ed\u1103\'ff? \u1071\'df, \u1073\'e1\u1099\'fb\u1074\'e2\u1072\'e0\u1083\'eb\u1086\'ee,}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1061\'d5\u1088\'f0\u1072\'e0\u1085\'ed\u1080\'e8\u1083\'eb\u1072\'e0 \u1074\'e2 \u1087\'ef\u1072\'e0\u1084\'ec\u1103\'ff\u1090\'f2\u1080\'e8 \u1085\'ed\u1077\'e5 \u1084\'ec\u1072\'e0\u1083\'eb\u1086\'ee}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1057\'d1\u1090\'f2\u1072\'e0\u1088\'f0\u1080\'e8\u1085\'ed\u1085\'ed\u1099\'fb\u1093\'f5 \u1073\'e1\u1099\'fb\u1083\'eb\u1077\'e5\u1081\'e9, \u1085\'ed\u1077\'e5\u1073\'e1\u1099\'fb\u1083\'eb\u1080\'e8\u1094\'f6}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1055\'cf\u1088\'f0\u1086\'ee \u1079\'e7\u1083\'eb\u1099\'fb\u1093\'f5 \u1076\'e4\u1091\'f3\u1093\'f5\u1086\'ee\u1074\'e2 \u1080\'e8 \u1087\'ef\u1088\'f0\u1086\'ee \u1076\'e4\u1077\'e5\u1074\'e2\u1080\'e8\u1094\'f6;}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1040\'c0 \u1085\'ed\u1099\'fb\u1085\'ed\u1095\'f7\u1077\'e5 \u1074\'e2\u1089\'f1\u1105\'b8 \u1084\'ec\u1085\'ed\u1077\'e5 \u1090\'f2\u1105\'b8\u1084\'ec\u1085\'ed\u1086\'ee, \u1058\'d2\u1072\'e0\u1085\'ed\u1103\'ff:}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1063\'d7\u1090\'f2\u1086\'ee \u1079\'e7\u1085\'ed\u1072\'e0\u1083\'eb\u1072\'e0, \u1090\'f2\u1086\'ee \u1079\'e7\u1072\'e0\u1073\'e1\u1099\'fb\u1083\'eb\u1072\'e0. \u1044\'c4\u1072\'e0,}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1055\'cf\u1088\'f0\u1080\'e8\u1096\'f8\u1083\'eb\u1072\'e0 \u1093\'f5\u1091\'f3\u1076\'e4\u1072\'e0\u1103\'ff \u1095\'f7\u1077\'e5\u1088\'f0\u1077\'e5\u1076\'e4\u1072\'e0!}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1047\'c7\u1072\'e0\u1096\'f8\u1080\'e8\u1073\'e1\u1083\'eb\u1086\'ee\u8230\'85\u187\'bb\~\u8211\'96 \u171\'ab\u1056\'d0\u1072\'e0\u1089\'f1\u1089\'f1\u1082\'ea\u1072\'e0\u1078\'e6\u1080\'e8 \u1084\'ec\u1085\'ed\u1077\'e5, \u1085\'ed\u1103\'ff\u1085\'ed\u1103\'ff,}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1055\'cf\u1088\'f0\u1086\'ee \u1074\'e2\u1072\'e0\u1096\'f8\u1080\'e8 \u1089\'f1\u1090\'f2\u1072\'e0\u1088\'f0\u1099\'fb\u1077\'e5 \u1075\'e3\u1086\'ee\u1076\'e4\u1072\'e0:}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1041\'c1\u1099\'fb\u1083\'eb\u1072\'e0 \u1090\'f2\u1099\'fb \u1074\'e2\u1083\'eb\u1102\'fe\u1073\'e1\u1083\'eb\u1077\'e5\u1085\'ed\u1072\'e0 \u1090\'f2\u1086\'ee\u1075\'e3\u1076\'e4\u1072\'e0?\u187\'bb\~\u8212\'97}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar

