\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar

\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1044\'c4\u1077\'e5\u1074\'e2\u1080\'e8\u1094\'f6\u1099\'fb, \u1082\'ea\u1088\'f0\u1072\'e0\u1089\'f1\u1072\'e0\u1074\'e2\u1080\'e8\u1094\'f6\u1099\'fb,}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1044\'c4\u1091\'f3\u1096\'f8\u1077\'e5\u1085\'ed\u1100\'fc\u1082\'ea\u1080\'e8, \u1087\'ef\u1086\'ee\u1076\'e4\u1088\'f0\u1091\'f3\u1078\'e6\u1077\'e5\u1085\'ed\u1100\'fc\u1082\'ea\u1080\'e8,}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1056\'d0\u1072\'e0\u1079\'e7\u1099\'fb\u1075\'e3\u1088\'f0\u1072\'e0\u1081\'e9\u1090\'f2\u1077\'e5\u1089\'f1\u1100\'fc, \u1076\'e4\u1077\'e5\u1074\'e2\u1080\'e8\u1094\'f6\u1099\'fb,}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1056\'d0\u1072\'e0\u1079\'e7\u1075\'e3\u1091\'f3\u1083\'eb\u1103\'ff\u1081\'e9\u1090\'f2\u1077\'e5\u1089\'f1\u1100\'fc, \u1084\'ec\u1080\'e8\u1083\'eb\u1099\'fb\u1077\'e5!}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1047\'c7\u1072\'e0\u1090\'f2\u1103\'ff\u1085\'ed\u1080\'e8\u1090\'f2\u1077\'e5 \u1087\'ef\u1077\'e5\u1089\'f1\u1077\'e5\u1085\'ed\u1082\'ea\u1091\'f3,}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1055\'cf\u1077\'e5\u1089\'f1\u1077\'e5\u1085\'ed\u1082\'ea\u1091\'f3 \u1079\'e7\u1072\'e0\u1074\'e2\u1077\'e5\u1090\'f2\u1085\'ed\u1091\'f3\u1102\'fe,}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1047\'c7\u1072\'e0\u1084\'ec\u1072\'e0\u1085\'ed\u1080\'e8\u1090\'f2\u1077\'e5 \u1084\'ec\u1086\'ee\u1083\'eb\u1086\'ee\u1076\'e4\u1094\'f6\u1072\'e0}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1050\'ca \u1093\'f5\u1086\'ee\u1088\'f0\u1086\'ee\u1074\'e2\u1086\'ee\u1076\'e4\u1091\'f3 \u1085\'ed\u1072\'e0\u1096\'f8\u1077\'e5\u1084\'ec\u1091\'f3.}
