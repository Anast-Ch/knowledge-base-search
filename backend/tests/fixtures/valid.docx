\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u171\'ab\u1063\'d7\u1090\'f2\u1086\'ee \u1078\'e6, \u1085\'ed\u1072\'e0\u1095\'f7\u1080\'e8\u1085\'ed\u1072\'e0\u1090\'f2\u1100\'fc?\u187\'bb\~\u8211\'96 \u171\'ab\u1053\'cd\u1072\'e0\u1095\'f7\u1085\'ed\u1077\'e5\u1084\'ec, \u1087\'ef\u1086\'ee\u1078\'e6\u1072\'e0\u1083\'eb\u1091\'f3\u1081\'e9\u187\'bb,\u8212\'97}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1057\'d1\u1082\'ea\u1072\'e0\u1079\'e7\u1072\'e0\u1083\'eb \u1042\'c2\u1083\'eb\u1072\'e0\u1076\'e4\u1080\'e8\u1084\'ec\u1080\'e8\u1088\'f0. \u1048\'c8 \u1087\'ef\u1086\'ee\u1096\'f8\u1083\'eb\u1080\'e8}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1047\'c7\u1072\'e0 \u1084\'ec\u1077\'e5\u1083\'eb\u1100\'fc\u1085\'ed\u1080\'e8\u1094\'f6\u1091\'f3. \u1055\'cf\u1086\'ee\u1082\'ea\u1072\'e0 \u1074\'e2\u1076\'e4\u1072\'e0\u1083\'eb\u1080\'e8}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
