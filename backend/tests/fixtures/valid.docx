\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1041\'c1\u1083\'eb\u1072\'e0\u1078\'e6\u1077\'e5\u1085\'ed, \u1082\'ea\u1090\'f2\u1086\'ee \u1074\'e2\u1077\'e5\u1076\'e4\u1072\'e0\u1083\'eb \u1080\'e8\u1093\'f5 \u1074\'e2\u1086\'ee\u1083\'eb\u1085\'ed\u1077\'e5\u1085\'ed\u1100\'fc\u1103\'ff}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1048\'c8 \u1085\'ed\u1072\'e0\u1082\'ea\u1086\'ee\u1085\'ed\u1077\'e5\u1094\'f6 \u1086\'ee\u1090\'f2 \u1085\'ed\u1080\'e8\u1093\'f5 \u1086\'ee\u1090\'f2\u1089\'f1\u1090\'f2\u1072\'e0\u1083\'eb;}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1041\'c1\u1083\'eb\u1072\'e0\u1078\'e6\u1077\'e5\u1085\'ed\u1085\'ed\u1077\'e5\u1081\'e9 \u1090\'f2\u1086\'ee\u1090\'f2, \u1082\'ea\u1090\'f2\u1086\'ee \u1080\'e8\u1093\'f5 \u1085\'ed\u1077\'e5 \u1079\'e7\u1085\'ed\u1072\'e0\u1083\'eb,}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
