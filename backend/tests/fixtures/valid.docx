\u1054\'ce\u1076\'e4\u1080\'e8\u1085\'ed, \u1074\'e2 \u1088\'f0\u1072\'e0\u1089\'f1\u1095\'f7\u1077\'e5\u1090\'f2\u1099\'fb \u1087\'ef\u1086\'ee\u1075\'e3\u1088\'f0\u1091\'f3\u1078\'e6\u1077\'e5\u1085\'ed\u1085\'ed\u1099\'fb\u1081\'e9,}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1058\'d2\u1091\'f3\u1087\'ef\u1099\'fb\u1084\'ec \u1082\'ea\u1080\'e8\u1077\'e5\u1084\'ec \u1074\'e2\u1086\'ee\u1086\'ee\u1088\'f0\u1091\'f3\u1078\'e6\u1077\'e5\u1085\'ed\u1085\'ed\u1099\'fb\u1081\'e9,}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1054\'ce\u1085\'ed \u1085\'ed\u1072\'e0 \u1073\'e1\u1080\'e8\u1083\'eb\u1100\'fc\u1103\'ff\u1088\'f0\u1076\'e4\u1077\'e5 \u1074\'e2 \u1076\'e4\u1074\'e2\u1072\'e0 \u1096\'f8\u1072\'e0\u1088\'f0\u1072\'e0}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
