\u1041\'c1\u1077\'e5\u1079\'e7 \u1079\'e7\u1074\'e2\u1077\'e5\u1079\'e7\u1076\'e4 \u1080\'e8 \u1073\'e1\u1077\'e5\u1079\'e7 \u1084\'ec\u1077\'e5\u1089\'f1\u1103\'ff\u1094\'f6\u1072\'e0 \u1074\'e2\u1089\'f1\u1103\'ff \u1086\'ee\u1079\'e7\u1072\'e0\u1088\'f0\u1103\'ff\u1077\'e5\u1090\'f2\u1089\'f1\u1103\'ff \u1076\'e4\u1072\'e0\u1083\'eb\u1100\'fc\u1085\'ed\u1086\'ee\u1089\'f1\u1090\'f2\u1100\'fc.}
\par \pard\plain \s36\ql\li500\lin500\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs18\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs18\lang1049\i0\b0{
\u1053\'cd\u1072\'e0 \u1074\'e2\u1079\'e7\u1084\'ec\u1086\'ee\u1088\'f0\u1100\'fc\u1077\'e5 \u1076\'e4\u1072\'e0\u1083\'eb\u1077\'e5\u1082\'ea\u1086\'ee\u1084\'ec \u1089\'f1\u1088\'f0\u1077\'e5\u1073\'e1\u1088\'f0\u1080\'e8\u1089\'f1\u1090\'f2\u1099\'fb\u1077\'e5 \u1074\'e2\u1080\'e8\u1076\'e4\u1085\'ed\u1099\'fb \u1074\'e2\u1077\'e5\u1090\'f2\u1088\'f0\u1080\'e8\u1083\'eb\u1072\'e0}
\par \pard\plain \s36\ql\li500\lin500\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs18\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs18\lang1049\i0\b0{
\u1063\'d7\u1091\'f3\u1090\'f2\u1100\'fc \u1074\'e2\u1080\'e8\u1076\'e4\u1085\'ed\u1099\'fb\u1093\'f5 \u1089\'f1\u1091\'f3\u1076\'e4\u1086\'ee\u1074\'e2, \u1082\'ea\u1072\'e0\u1082\'ea \u1087\'ef\u1086\'ee \u1089\'f1\u1080\'e8\u1085\'ed\u1077\'e5\u1084\'ec\u1091\'f3 \u1085\'ed\u1077\'e5\u1073\'e1\u1091\'f3 \u1087\'ef\u1083\'eb\u1099\'fb\u1074\'e2\u1091\'f3\u1097\'f9\u1080\'e8\u1093\'f5.}
\par \pard\plain \s36\ql\li500\lin500\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs18\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs18\lang1049\i0\b0{
\u1057\'d1\u1080\'e8\u1103\'ff\u1085\'ed\u1100\'fc\u1077\'e5\u1084\'ec \u1073\'e1\u1077\'e5\u1089\'f1\u1089\'f1\u1091\'f3\u1084\'ec\u1088\'f0\u1072\'e0\u1095\'f7\u1085\'ed\u1099\'fb\u1084\'ec \u1085\'ed\u1077\'e5\u1073\'e1\u1086\'ee \u1085\'ed\u1086\'ee\u1095\'f7\u1085\'ed\u1086\'ee\u1077\'e5 \u1089\'f1\u1080\'e8\u1103\'ff\u1077\'e5\u1090\'f2,}
\par \pard\plain \s36\ql\li500\lin500\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs18\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs18\lang1049\i0\b0{
\u1048\'c8 \u1087\'ef\u1091\'f3\u1088\'f0\u1087\'ef\u1091\'f3\u1088\'f0 \u1079\'e7\u1072\'e0\u1082\'ea\u1072\'e0\u1090\'f2\u1072\'e0 \u1089\'f1\u1083\'eb\u1080\'e8\u1074\'e2\u1072\'e0\u1077\'e5\u1090\'f2\u1089\'f1\u1103\'ff \u1089\'f1 \u1079\'e7\u1083\'eb\u1072\'e0\u1090\'f2\u1086\'ee\u1084\'ec \u1074\'e2\u1086\'ee\u1089\'f1\u1090\'f2\u1086\'ee\u1082\'ea\u1072\'e0:}
\par \pard\plain \s36\ql\li500\lin500\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs18\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs18\lang1049\i0\b0{
\u1050\'ca\u1072\'e0\u1082\'ea \u1073\'e1\u1091\'f3\u1076\'e4\u1090\'f2\u1086\'ee \u1076\'e4\u1077\'e5\u1085\'ed\u1085\'ed\u1080\'e8\u1094\'f6\u1072\'e0 \u1079\'e7\u1072\'e0 \u1074\'e2\u1077\'e5\u1095\'f7\u1077\'e5\u1088\'f0\u1086\'ee\u1084\'ec \u1089\'f1\u1083\'eb\u1077\'e5\u1076\'e4\u1086\'ee\u1084\'ec \u1074\'e2\u1099\'fb\u1074\'e2\u1086\'ee\u1076\'e4\u1080\'e8\u1090\'f2}
\par \pard\plain \s36\ql\li500\lin500\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs18\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs18\lang1049\i0\b0{
\u1056\'d0\u1091\'f3\u1084\'ec\u1103\'ff\u1085\'ed\u1086\'ee\u1077\'e5 \u1091\'f3\u1090\'f2\u1088\'f0\u1086\'ee.\~\u8211\'96 \u1041\'c1\u1099\'fb\u1083\'eb\u1072\'e0 \u1090\'f2\u1086\'ee \u1075\'e3\u1086\'ee\u1076\'e4\u1080\'e8\u1085\'ed\u1072\'e0 \u1079\'e7\u1083\'eb\u1072\'e0\u1090\'f2\u1072\'e0\u1103\'ff.}
\par \pard\plain \s36\ql\li500\lin500\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs18\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs18\lang1049\i0\b0{
\u1050\'ca\u1072\'e0\u1082\'ea \u1083\'eb\u1077\'e5\u1090\'f2\u1085\'ed\u1080\'e8\u1077\'e5 \u1076\'e4\u1085\'ed\u1080\'e8 \u1087\'ef\u1086\'ee\u1093\'f5\u1080\'e8\u1097\'f9\u1072\'e0\u1102\'fe\u1090\'f2 \u1074\'e2\u1083\'eb\u1072\'e0\u1076\'e4\u1099\'fb\u1095\'f7\u1077\'e5\u1089\'f1\u1090\'f2\u1074\'e2\u1086\'ee \u1085\'ed\u1086\'ee\u1095\'f7\u1080\'e8;}
\par \pard\plain \s36\ql\li500\lin500\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs18\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs18\lang1049\i0\b0{
\u1050\'ca\u1072\'e0\u1082\'ea \u1074\'e2\u1079\'e7\u1086\'ee\u1088\'f0 \u1080\'e8\u1085\'ed\u1086\'ee\u1079\'e7\u1077\'e5\u1084\'ec\u1094\'f6\u1072\'e0 \u1085\'ed\u1072\'e0 \u1089\'f1\u1077\'e5\u1074\'e2\u1077\'e5\u1088\'f0\u1085\'ed\u1086\'ee\u1084\'ec \u1085\'ed\u1077\'e5\u1073\'e1\u1077\'e5 \u1087\'ef\u1083\'eb\u1077\'e5\u1085\'ed\u1103\'ff\u1077\'e5\u1090\'f2}
\par \pard\plain \s36\ql\li500\lin500\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs18\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs18\lang1049\i0\b0{
\u1057\'d1\u1080\'e8\u1103\'ff\u1085\'ed\u1100\'fc\u1077\'e5 \u1074\'e2\u1086\'ee\u1083\'eb\u1096\'f8\u1077\'e5\u1073\'e1\u1085\'ed\u1086\'ee\u1077\'e5 \u1090\'f2\u1077\'e5\u1085\'ed\u1080\'e8 \u1080\'e8 \u1089\'f1\u1083\'eb\u1072\'e0\u1076\'e4\u1082\'ea\u1086\'ee\u1075\'e3\u1086\'ee \u1089\'f1\u1074\'e2\u1077\'e5\u1090\'f2\u1072\'e0,}
\par \pard\plain \s36\ql\li500\lin500\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs18\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs18\lang1049\i0\b0{
\u1050\'ca\u1072\'e0\u1082\'ea\u1080\'e8\u1084\'ec \u1085\'ed\u1080\'e8\u1082\'ea\u1086\'ee\u1075\'e3\u1076\'e4\u1072\'e0 \u1085\'ed\u1077\'e5 \u1091\'f3\u1082\'ea\u1088\'f0\u1072\'e0\u1096\'f8\u1077\'e5\u1085\'ed\u1086\'ee \u1085\'ed\u1077\'e5\u1073\'e1\u1086\'ee \u1087\'ef\u1086\'ee\u1083\'eb\u1091\'f3\u1076\'e4\u1085\'ed\u1103\'ff;}
\par \pard\plain \s36\ql\li500\lin500\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs18\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs18\lang1049\i0\b0{
\u1058\'d2\u1072\'e0 \u1103\'ff\u1089\'f1\u1085\'ed\u1086\'ee\u1089\'f1\u1090\'f2\u1100\'fc, \u1087\'ef\u1086\'ee\u1076\'e4\u1086\'ee\u1073\'e1\u1085\'ed\u1072\'e0\u1103\'ff \u1087\'ef\u1088\'f0\u1077\'e5\u1083\'eb\u1077\'e5\u1089\'f1\u1090\'f2\u1103\'ff\u1084\'ec \u1089\'f1\u1077\'e5\u1074\'e2\u1077\'e5\u1088\'f0\u1085\'ed\u1086\'ee\u1081\'e9 \u1076\'e4\u1077\'e5\u1074\'e2\u1099\'fb,}
\par \pard\plain \s36\ql\li500\lin500\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs18\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs18\lang1049\i0\b0{
\u1050\'ca\u1086\'ee\u1090\'f2\u1086\'ee\u1088\'f0\u1086\'ee\u1081\'e9 \u1075\'e3\u1083\'eb\u1072\'e0\u1079\'e7\u1072\'e0 \u1075\'e3\u1086\'ee\u1083\'eb\u1091\'f3\u1073\'e1\u1099\'fb\u1077\'e5 \u1080\'e8 \u1072\'e0\u1083\'eb\u1099\'fb\u1077\'e5 \u1097\'f9\u1077\'e5\u1082\'ea\u1080\'e8}
\par \pard\plain \s36\ql\li500\lin500\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs18\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs18\lang1049\i0\b0{
\u1045\'c5\u1076\'e4\u1074\'e2\u1072\'e0 \u1086\'ee\u1090\'f2\u1090\'f2\u1077\'e5\u1085\'ed\u1103\'ff\u1102\'fe\u1090\'f2\u1089\'f1\u1103\'ff \u1088\'f0\u1091\'f3\u1089\'f1\u1099\'fb\u1084\'ec\u1080\'e8 \u1083\'eb\u1086\'ee\u1082\'ea\u1086\'ee\u1085\'ed \u1074\'e2\u1086\'ee\u1083\'eb\u1085\'ed\u1072\'e0\u1084\'ec\u1080\'e8.}
\par \pard\plain \s36\ql\li500\lin500\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs18\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs18\lang1049\i0\b0{
\u1058\'d2\u1086\'ee\u1075\'e3\u1076\'e4\u1072\'e0 \u1085\'ed\u1072\'e0\u1076\'e4 \u1053\'cd\u1077\'e5\u1074\'e2\u1086\'ee\u1081\'e9 \u1080\'e8 \u1085\'ed\u1072\'e0\u1076\'e4 \u1087\'ef\u1099\'fb\u1096\'f8\u1085\'ed\u1099\'fb\u1084\'ec \u1055\'cf\u1077\'e5\u1090\'f2\u1088\'f0\u1086\'ee\u1087\'ef\u1086\'ee\u1083\'eb\u1077\'e5\u1084\'ec \u1074\'e2\u1080\'e8\u1076\'e4\u1103\'ff\u1090\'f2}
\par \pard\plain \s36\ql\li500\lin500\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs18\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs18\lang1049\i0\b0{
\u1041\'c1\u1077\'e5\u1079\'e7 \u1089\'f1\u1091\'f3\u1084\'ec\u1088\'f0\u1072\'e0\u1082\'ea\u1072\'e0 \u1074\'e2\u1077\'e5\u1095\'f7\u1077\'e5\u1088\'f0 \u1080\'e8 \u1073\'e1\u1099\'fb\u1089\'f1\u1090\'f2\u1088\'f0\u1099\'fb\u1077\'e5 \u1085\'ed\u1086\'ee\u1095\'f7\u1080\'e8 \u1073\'e1\u1077\'e5\u1079\'e7 \u1090\'f2\u1077\'e5\u1085\'ed\u1080\'e8;}
\par \pard\plain \s36\ql\li500\lin500\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs18\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs18\lang1049\i0\b0{
\u1058\'d2\u1086\'ee\u1075\'e3\u1076\'e4\u1072\'e0 \u1060\'d4\u1080\'e8\u1083\'eb\u1086\'ee\u1084\'ec\u1077\'e5\u1083\'eb\u1072\'e0 \u1087\'ef\u1086\'ee\u1083\'eb\u1085\'ed\u1086\'ee\u1095\'f7\u1085\'ed\u1099\'fb\u1077\'e5 \u1087\'ef\u1077\'e5\u1089\'f1\u1085\'ed\u1080\'e8 \u1083\'eb\u1080\'e8\u1096\'f8\u1100\'fc \u1082\'ea\u1086\'ee\u1085\'ed\u1095\'f7\u1080\'e8\u1090\'f2}
\par \pard\plain \s36\ql\li500\lin500\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs18\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs18\lang1049\i0\b0{
\u1048\'c8 \u1087\'ef\u1077\'e5\u1089\'f1\u1085\'ed\u1080\'e8 \u1079\'e7\u1072\'e0\u1074\'e2\u1086\'ee\u1076\'e4\u1080\'e8\u1090\'f2, \u1087\'ef\u1088\'f0\u1080\'e8\u1074\'e2\u1077\'e5\u1090\'f2\u1089\'f1\u1090\'f2\u1074\'e2\u1091\'f3\u1103\'ff \u1076\'e4\u1077\'e5\u1085\'ed\u1100\'fc \u1074\'e2\u1086\'ee\u1089\'f1\u1093\'f5\u1086\'ee\u1076\'e4\u1103\'ff\u1097\'f9\u1080\'e8\u1081\'e9.}
\par \pard\plain \s36\ql\li500\lin500\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs18\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs18\lang1049\i0\b0{
\u1053\'cd\u1086\'ee \u1087\'ef\u1086\'ee\u1079\'e7\u1076\'e4\u1085\'ed\u1086\'ee; \u1087\'ef\u1086\'ee\u1074\'e2\u1077\'e5\u1103\'ff\u1083\'eb\u1072\'e0 \u1089\'f1\u1074\'e2\u1077\'e5\u1078\'e6\u1077\'e5\u1089\'f1\u1090\'f2\u1100\'fc \u1085\'ed\u1072\'e0 \u1085\'ed\u1077\'e5\u1074\'e2\u1089\'f1\u1082\'ea\u1080\'e8\u1077\'e5 \u1090\'f2\u1091\'f3\u1085\'ed\u1076\'e4\u1088\'f0\u1099\'fb;}
\par \pard\plain \s36\ql\li500\lin500\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs18\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs18\lang1049\i0\b0{
\u1056\'d0\u1086\'ee\u1089\'f1\u1072\'e0 \u1086\'ee\u1087\'ef\u1091\'f3\u1089\'f1\u1090\'f2\u1080\'e8\u1083\'eb\u1072\'e0\u1089\'f1\u1100\'fc; \u8230\'85\u8230\'85\u8230\'85\u8230\'85\u8230\'85\u8230\'85\u8230\'85\u8230\'85\u8230\'85}
\par \pard\plain \s36\ql\li500\lin500\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs18\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs18\lang1049\i0\b0{
\u1042\'c2\u1086\'ee\u1090\'f2 \u1087\'ef\u1086\'ee\u1083\'eb\u1085\'ed\u1086\'ee\u1095\'f7\u1100\'fc: \u1096\'f8\u1091\'f3\u1084\'ec\u1077\'e5\u1074\'e2\u1096\'f8\u1072\'e0\u1103\'ff \u1074\'e2\u1077\'e5\u1095\'f7\u1077\'e5\u1088\'f0\u1086\'ee\u1084\'ec \u1090\'f2\u1099\'fb\u1089\'f1\u1103\'ff\u1095\'f7\u1100\'fc\u1102\'fe \u1074\'e2\u1077\'e5\u1089\'f1\u1077\'e5\u1083\'eb,}
\par \pard\plain \s36\ql\li500\lin500\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs18\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs18\lang1049\i0\b0{
\u1053\'cd\u1077\'e5\u1074\'e2\u1072\'e0 \u1085\'ed\u1077\'e5 \u1082\'ea\u1086\'ee\u1083\'eb\u1099\'fb\u1093\'f5\u1085\'ed\u1077\'e5\u1090\'f2; \u1088\'f0\u1072\'e0\u1079\'e7\u1098\'fa\u1077\'e5\u1093\'f5\u1072\'e0\u1083\'eb\u1080\'e8\u1089\'f1\u1100\'fc \u1075\'e3\u1086\'ee\u1089\'f1\u1090\'f2\u1080\'e8 \u1075\'e3\u1088\'f0\u1072\'e0\u1076\'e4\u1089\'f1\u1082\'ea\u1080\'e8\u1077\'e5;}
\par \pard\plain \s36\ql\li500\lin500\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs18\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs18\lang1049\i0\b0{
\u1053\'cd\u1080\'e8 \u1075\'e3\u1083\'eb\u1072\'e0\u1089\'f1\u1072\'e0 \u1085\'ed\u1072\'e0 \u1073\'e1\u1088\'f0\u1077\'e5\u1075\'e3\u1077\'e5, \u1085\'ed\u1080\'e8 \u1079\'e7\u1099\'fb\u1073\'e1\u1080\'e8 \u1085\'ed\u1072\'e0 \u1074\'e2\u1083\'eb\u1072\'e0\u1075\'e3\u1077\'e5, \u1074\'e2\u1089\'f1\u1077\'e5 \u1090\'f2\u1080\'e8\u1093\'f5\u1086\'ee;}
\par \pard\plain \s36\ql\li500\lin500\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs18\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs18\lang1049\i0\b0{
