\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1057\'d1\u1084\'ec\u1077\'e5\u1083\'eb \u1095\'f7\u1080\'e8\u1089\'f1\u1090\'f2\u1080\'e8\u1090\'f2\u1100\'fc \u1085\'ed\u1086\'ee\u1075\'e3\u1090\'f2\u1080\'e8 \u1087\'ef\u1077\'e5\u1088\'f0\u1077\'e5\u1076\'e4 \u1085\'ed\u1080\'e8\u1084\'ec,}
\par \ql\fi567\li0\lin0\ri0\rin0\sb0\sa0\ltrpar\fi567\li300\lin300\ri600\rin600\sb0\sa0\ltrpar\fi567\li350\lin350\ri600\rin600\sb0\sa0\ltrpar\ql\fi567\li0\lin0\ri0\rin0\sb0\sa0\ltrpar\ql\fi567\li0\lin0\ri0\rin0\sb0\sa0\ltrpar\fi567\li300\lin300\ri600\rin600\sb0\sa0\ltrpar\fi567\li350\lin350\ri600\rin600\sb0\sa0\ltrpar\ql\fi567\li0\lin0\ri0\rin0\sb0\sa0\ltrpar\fi200\li0\lin0\ri0\rin0\sb0\sa0\ltrpar\ltrpar\pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1050\'ca\u1088\'f0\u1072\'e0\u1089\'f1\u1085\'ed\u1086\'ee\u1088\'f0\u1077\'e5\u1095\'f7\u1080\'e8\u1074\'e2\u1099\'fb\u1084\'ec \u1089\'f1\u1091\'f3\u1084\'ec\u1072\'e0\u1089\'f1\u1073\'e1\u1088\'f0\u1086\'ee\u1076\'e4\u1086\'ee\u1084\'ec}{{\super \chftn{\*\footnote \chftn\pard\plain \s0\qj\fi567\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0{
 }
\par \pard\plain \s37\qj\li300\lin300\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs18\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs18\lang1049\i0\b0{
Tout le monde sut qu\u8217\'92il mettait du blanc; et moi, qui n\u8217\'92en croyais rien, je commen\u1079\'e7ai de le croire, non seulement par l\u8217\'92embellissement de son teint et pour avoir trouve\u8364\'88 des tasses de blanc sur sa toilette, mais sur ce qu\u8217\'92entrant un matin dans sa chambre, je le trouvai brossant ses ongles avec une petite vergette faite expr\u1080\'e8s, ouvrage qu\u8217\'92il continua fi\u1080\'e8rement devant moi. Je jugeai qu\u8217\'92un homme qui passe deux heures tous les matins \u1072\'e0 brosser ses ongles, peut bien passer quelques instants \u1072\'e0 remplir de blanc les creux de sa peau.}
\par \pard\plain \s38\qj\li350\lin350\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs18\alang1049\ai\ab\dbch\af9\langfe2052\loch\f5\fs18\lang1049\i\b{
Confessions J. J. Rousseau}{\i0
 }
{\hich\ai0\dbch\ai0\loch\i0\par}\pard\plain \s0\qj\fi567\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0

\par \pard\plain \s0\qj\fi567\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0

\par \pard\plain \s37\qj\li300\lin300\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs18\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs18\lang1049\i0\b0{
\u1042\'c2\u1089\'f1\u1077\'e5 \u1079\'e7\u1085\'ed\u1072\'e0\u1083\'eb\u1080\'e8, \u1095\'f7\u1090\'f2\u1086\'ee \u1086\'ee\u1085\'ed \u1091\'f3\u1087\'ef\u1086\'ee\u1090\'f2\u1088\'f0\u1077\'e5\u1073\'e1\u1083\'eb\u1103\'ff\u1077\'e5\u1090\'f2 \u1073\'e1\u1077\'e5\u1083\'eb\u1080\'e8\u1083\'eb\u1072\'e0; \u1080\'e8 \u1103\'ff, \u1089\'f1\u1086\'ee\u1074\'e2\u1077\'e5\u1088\'f0\u1096\'f8\u1077\'e5\u1085\'ed\u1085\'ed\u1086\'ee \u1101\'fd\u1090\'f2\u1086\'ee\u1084\'ec\u1091\'f3 \u1085\'ed\u1077\'e5 \u1074\'e2\u1077\'e5\u1088\'f0\u1080\'e8\u1074\'e2\u1096\'f8\u1080\'e8\u1081\'e9, \u1085\'ed\u1072\'e0\u1095\'f7\u1072\'e0\u1083\'eb \u1076\'e4\u1086\'ee\u1075\'e3\u1072\'e0\u1076\'e4\u1099\'fb\u1074\'e2\u1072\'e0\u1090\'f2\u1100\'fc\u1089\'f1\u1103\'ff \u1086\'ee \u1090\'f2\u1086\'ee\u1084\'ec \u1085\'ed\u1077\'e5 \u1090\'f2\u1086\'ee\u1083\'eb\u1100\'fc\u1082\'ea\u1086\'ee \u1087\'ef\u1086\'ee \u1091\'f3\u1083\'eb\u1091\'f3\u1095\'f7\u1096\'f8\u1077\'e5\u1085\'ed\u1080\'e8\u1102\'fe \u1094\'f6\u1074\'e2\u1077\'e5\u1090\'f2\u1072\'e0 \u1077\'e5\u1075\'e3\u1086\'ee \u1083\'eb\u1080\'e8\u1094\'f6\u1072\'e0 \u1080\'e8\u1083\'eb\u1080\'e8 \u1087\'ef\u1086\'ee\u1090\'f2\u1086\'ee\u1084\'ec\u1091\'f3, \u1095\'f7\u1090\'f2\u1086\'ee \u1085\'ed\u1072\'e0\u1093\'f5\u1086\'ee\u1076\'e4\u1080\'e8\u1083\'eb \u1073\'e1\u1072\'e0\u1085\'ed\u1086\'ee\u1095\'f7\u1082\'ea\u1080\'e8 \u1080\'e8\u1079\'e7-\u1087\'ef\u1086\'ee\u1076\'e4 \u1073\'e1\u1077\'e5\u1083\'eb\u1080\'e8\u1083\'eb \u1085\'ed\u1072\'e0 \u1077\'e5\u1075\'e3\u1086\'ee \u1090\'f2\u1091\'f3\u1072\'e0\u1083\'eb\u1077\'e5\u1090\'f2\u1077\'e5, \u1085\'ed\u1086\'ee \u1087\'ef\u1086\'ee\u1090\'f2\u1086\'ee\u1084\'ec\u1091\'f3, \u1095\'f7\u1090\'f2\u1086\'ee, \u1079\'e7\u1072\'e0\u1081\'e9\u1076\'e4\u1103\'ff \u1086\'ee\u1076\'e4\u1085\'ed\u1072\'e0\u1078\'e6\u1076\'e4\u1099\'fb \u1091\'f3\u1090\'f2\u1088\'f0\u1086\'ee\u1084\'ec \u1082\'ea \u1085\'ed\u1077\'e5\u1084\'ec\u1091\'f3 \u1074\'e2 \u1082\'ea\u1086\'ee\u1084\'ec\u1085\'ed\u1072\'e0\u1090\'f2\u1091\'f3, \u1103\'ff \u1079\'e7\u1072\'e0\u1089\'f1\u1090\'f2\u1072\'e0\u1083\'eb \u1077\'e5\u1075\'e3\u1086\'ee \u1079\'e7\u1072\'e0 \u1095\'f7\u1080\'e8\u1089\'f1\u1090\'f2\u1082\'ea\u1086\'ee\u1081\'e9 \u1085\'ed\u1086\'ee\u1075\'e3\u1090\'f2\u1077\'e5\u1081\'e9 \u1087\'ef\u1088\'f0\u1080\'e8 \u1087\'ef\u1086\'ee\u1084\'ec\u1086\'ee\u1097\'f9\u1080\'e8 \u1089\'f1\u1087\'ef\u1077\'e5\u1094\'f6\u1080\'e8\u1072\'e0\u1083\'eb\u1100\'fc\u1085\'ed\u1086\'ee\u1081\'e9 \u1097\'f9\u1077\'e5\u1090\'f2\u1086\'ee\u1095\'f7\u1082\'ea\u1080\'e8; \u1101\'fd\u1090\'f2\u1086\'ee \u1079\'e7\u1072\'e0\u1085\'ed\u1103\'ff\u1090\'f2\u1080\'e8\u1077\'e5 \u1086\'ee\u1085\'ed \u1075\'e3\u1086\'ee\u1088\'f0\u1076\'e4\u1086\'ee \u1087\'ef\u1088\'f0\u1086\'ee\u1076\'e4\u1086\'ee\u1083\'eb\u1078\'e6\u1072\'e0\u1083\'eb \u1074\'e2 \u1084\'ec\u1086\'ee\u1077\'e5\u1084\'ec \u1087\'ef\u1088\'f0\u1080\'e8\u1089\'f1\u1091\'f3\u1090\'f2\u1089\'f1\u1090\'f2\u1074\'e2\u1080\'e8\u1080\'e8. \u1071\'df \u1088\'f0\u1077\'e5\u1096\'f8\u1080\'e8\u1083\'eb, \u1095\'f7\u1090\'f2\u1086\'ee \u1095\'f7\u1077\'e5\u1083\'eb\u1086\'ee\u1074\'e2\u1077\'e5\u1082\'ea, \u1082\'ea\u1086\'ee\u1090\'f2\u1086\'ee\u1088\'f0\u1099\'fb\u1081\'e9 \u1082\'ea\u1072\'e0\u1078\'e6\u1076\'e4\u1086\'ee\u1077\'e5 \u1091\'f3\u1090\'f2\u1088\'f0\u1086\'ee \u1087\'ef\u1088\'f0\u1086\'ee\u1074\'e2\u1086\'ee\u1076\'e4\u1080\'e8\u1090\'f2 \u1076\'e4\u1074\'e2\u1072\'e0 \u1095\'f7\u1072\'e0\u1089\'f1\u1072\'e0 \u1079\'e7\u1072\'e0 \u1095\'f7\u1080\'e8\u1089\'f1\u1090\'f2\u1082\'ea\u1086\'ee\u1081\'e9 \u1085\'ed\u1086\'ee\u1075\'e3\u1090\'f2\u1077\'e5\u1081\'e9, \u1084\'ec\u1086\'ee\u1078\'e6\u1077\'e5\u1090\'f2 \u1087\'ef\u1086\'ee\u1090\'f2\u1088\'f0\u1072\'e0\u1090\'f2\u1080\'e8\u1090\'f2\u1100\'fc \u1085\'ed\u1077\'e5\u1089\'f1\u1082\'ea\u1086\'ee\u1083\'eb\u1100\'fc\u1082\'ea\u1086\'ee \u1084\'ec\u1080\'e8\u1085\'ed\u1091\'f3\u1090\'f2, \u1095\'f7\u1090\'f2\u1086\'ee\u1073\'e1\u1099\'fb \u1079\'e7\u1072\'e0\u1084\'ec\u1072\'e0\u1079\'e7\u1072\'e0\u1090\'f2\u1100\'fc \u1073\'e1\u1077\'e5\u1083\'eb\u1080\'e8\u1083\'eb\u1072\'e0\u1084\'ec\u1080\'e8 \u1085\'ed\u1077\'e5\u1076\'e4\u1086\'ee\u1089\'f1\u1090\'f2\u1072\'e0\u1090\'f2\u1082\'ea\u1080\'e8 \u1082\'ea\u1086\'ee\u1078\'e6\u1080\'e8.}
