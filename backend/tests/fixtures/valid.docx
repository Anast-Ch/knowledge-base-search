\u1063\'d7\u1077\'e5\u1090\'f2\u1072\'e0 \u1084\'ec\u1077\'e5\u1083\'eb\u1100\'fc\u1082\'ea\u1072\'e0\u1077\'e5\u1090\'f2 \u1079\'e7\u1072\'e0 \u1095\'f7\u1077\'e5\u1090\'f2\u1086\'ee\u1081\'e9.}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1050\'ca \u1084\'ec\u1080\'e8\u1085\'ed\u1091\'f3\u1090\'f2\u1077\'e5 \u1084\'ec\u1097\'f9\u1077\'e5\u1085\'ed\u1100\'fc\u1103\'ff \u1087\'ef\u1088\'f0\u1080\'e8\u1073\'e1\u1083\'eb\u1080\'e8\u1078\'e6\u1072\'e0\u1103\'ff\u1089\'f1\u1100\'fc,}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1054\'ce\u1085\'ed\u1077\'e5\u1075\'e3\u1080\'e8\u1085\'ed, \u1074\'e2\u1090\'f2\u1072\'e0\u1081\'e9\u1085\'ed\u1077\'e5 \u1091\'f3\u1089\'f1\u1084\'ec\u1077\'e5\u1093\'f5\u1072\'e0\u1103\'ff\u1089\'f1\u1100\'fc,}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1055\'cf\u1086\'ee\u1076\'e4\u1093\'f5\u1086\'ee\u1076\'e4\u1080\'e8\u1090\'f2 \u1082\'ea \u1054\'ce\u1083\'eb\u1100\'fc\u1075\'e3\u1077\'e5. \u1041\'c1\u1099\'fb\u1089\'f1\u1090\'f2\u1088\'f0\u1086\'ee \u1089\'f1 \u1085\'ed\u1077\'e5\u1081\'e9}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1042\'c2\u1077\'e5\u1088\'f0\u1090\'f2\u1080\'e8\u1090\'f2\u1089\'f1\u1103\'ff \u1086\'ee\u1082\'ea\u1086\'ee\u1083\'eb\u1086\'ee \u1075\'e3\u1086\'ee\u1089\'f1\u1090\'f2\u1077\'e5\u1081\'e9,}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1055\'cf\u1086\'ee\u1090\'f2\u1086\'ee\u1084\'ec \u1085\'ed\u1072\'e0 \u1089\'f1\u1090\'f2\u1091\'f3\u1083\'eb \u1077\'e5\u1077\'e5 \u1089\'f1\u1072\'e0\u1078\'e6\u1072\'e0\u1077\'e5\u1090\'f2,}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1047\'c7\u1072\'e0\u1074\'e2\u1086\'ee\u1076\'e4\u1080\'e8\u1090\'f2 \u1088\'f0\u1077\'e5\u1095\'f7\u1100\'fc \u1086\'ee \u1090\'f2\u1086\'ee\u1084\'ec, \u1086\'ee \u1089\'f1\u1077\'e5\u1084\'ec;}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1057\'d1\u1087\'ef\u1091\'f3\u1089\'f1\u1090\'f2\u1103\'ff \u1084\'ec\u1080\'e8\u1085\'ed\u1091\'f3\u1090\'f2\u1099\'fb \u1076\'e4\u1074\'e2\u1077\'e5 \u1087\'ef\u1086\'ee\u1090\'f2\u1086\'ee\u1084\'ec}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1042\'c2\u1085\'ed\u1086\'ee\u1074\'e2\u1100\'fc \u1089\'f1 \u1085\'ed\u1077\'e5\u1102\'fe \u1074\'e2\u1072\'e0\u1083\'eb\u1100\'fc\u1089\'f1 \u1086\'ee\u1085\'ed \u1087\'ef\u1088\'f0\u1086\'ee\u1076\'e4\u1086\'ee\u1083\'eb\u1078\'e6\u1072\'e0\u1077\'e5\u1090\'f2;}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1042\'c2\u1089\'f1\u1077\'e5 \u1074\'e2 \u1080\'e8\u1079\'e7\u1091\'f3\u1084\'ec\u1083\'eb\u1077\'e5\u1085\'ed\u1100\'fc\u1077\'e5. \u1051\'cb\u1077\'e5\u1085\'ed\u1089\'f1\u1082\'ea\u1080\'e8\u1081\'e9 \u1089\'f1\u1072\'e0\u1084\'ec}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1053\'cd\u1077\'e5 \u1074\'e2\u1077\'e5\u1088\'f0\u1080\'e8\u1090\'f2 \u1089\'f1\u1086\'ee\u1073\'e1\u1089\'f1\u1090\'f2\u1074\'e2\u1077\'e5\u1085\'ed\u1085\'ed\u1099\'fb\u1084\'ec \u1075\'e3\u1083\'eb\u1072\'e0\u1079\'e7\u1072\'e0\u1084\'ec.}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar

