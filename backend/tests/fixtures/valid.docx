\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1054\'ce\u1085\'ed\u1072\'e0 \u1087\'ef\u1086\'ee\u1101\'fd\u1090\'f2\u1091\'f3 \u1087\'ef\u1086\'ee\u1076\'e4\u1072\'e0\u1088\'f0\u1080\'e8\u1083\'eb\u1072\'e0}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1052\'cc\u1083\'eb\u1072\'e0\u1076\'e4\u1099\'fb\u1093\'f5 \u1074\'e2\u1086\'ee\u1089\'f1\u1090\'f2\u1086\'ee\u1088\'f0\u1075\'e3\u1086\'ee\u1074\'e2 \u1087\'ef\u1077\'e5\u1088\'f0\u1074\'e2\u1099\'fb\u1081\'e9 \u1089\'f1\u1086\'ee\u1085\'ed,}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1048\'c8 \u1084\'ec\u1099\'fb\u1089\'f1\u1083\'eb\u1100\'fc \u1086\'ee\u1073\'e1 \u1085\'ed\u1077\'e5\u1081\'e9 \u1086\'ee\u1076\'e4\u1091\'f3\u1096\'f8\u1077\'e5\u1074\'e2\u1080\'e8\u1083\'eb\u1072\'e0}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1045\'c5\u1075\'e3\u1086\'ee \u1094\'f6\u1077\'e5\u1074\'e2\u1085\'ed\u1080\'e8\u1094\'f6\u1099\'fb \u1087\'ef\u1077\'e5\u1088\'f0\u1074\'e2\u1099\'fb\u1081\'e9 \u1089\'f1\u1090\'f2\u1086\'ee\u1085\'ed.}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1055\'cf\u1088\'f0\u1086\'ee\u1089\'f1\u1090\'f2\u1080\'e8\u1090\'f2\u1077\'e5, \u1080\'e8\u1075\'e3\u1088\'f0\u1099\'fb \u1079\'e7\u1086\'ee\u1083\'eb\u1086\'ee\u1090\'f2\u1099\'fb\u1077\'e5!}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1054\'ce\u1085\'ed \u1088\'f0\u1086\'ee\u1097\'f9\u1080\'e8 \u1087\'ef\u1086\'ee\u1083\'eb\u1102\'fe\u1073\'e1\u1080\'e8\u1083\'eb \u1075\'e3\u1091\'f3\u1089\'f1\u1090\'f2\u1099\'fb\u1077\'e5,}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1059\'d3\u1077\'e5\u1076\'e4\u1080\'e8\u1085\'ed\u1077\'e5\u1085\'ed\u1100\'fc\u1077\'e5, \u1090\'f2\u1080\'e8\u1096\'f8\u1080\'e8\u1085\'ed\u1091\'f3,}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1048\'c8 \u1085\'ed\u1086\'ee\u1095\'f7\u1100\'fc, \u1080\'e8 \u1079\'e7\u1074\'e2\u1077\'e5\u1079\'e7\u1076\'e4\u1099\'fb, \u1080\'e8 \u1083\'eb\u1091\'f3\u1085\'ed\u1091\'f3,}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1051\'cb\u1091\'f3\u1085\'ed\u1091\'f3, \u1085\'ed\u1077\'e5\u1073\'e1\u1077\'e5\u1089\'f1\u1085\'ed\u1091\'f3\u1102\'fe \u1083\'eb\u1072\'e0\u1084\'ec\u1087\'ef\u1072\'e0\u1076\'e4\u1091\'f3,}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1050\'ca\u1086\'ee\u1090\'f2\u1086\'ee\u1088\'f0\u1086\'ee\u1081\'e9 \u1087\'ef\u1086\'ee\u1089\'f1\u1074\'e2\u1103\'ff\u1097\'f9\u1072\'e0\u1083\'eb\u1080\'e8 \u1084\'ec\u1099\'fb}
