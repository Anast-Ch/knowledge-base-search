\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1053\'cd\u1086\'ee \u1090\'f2\u1072\'e0\u1082\'ea \u1080\'e8 \u1073\'e1\u1099\'fb\u1090\'f2\u1100\'fc! \u1057\'d1\u1091\'f3\u1076\'e4\u1100\'fc\u1073\'e1\u1091\'f3 \u1084\'ec\u1086\'ee\u1102\'fe}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1054\'ce\u1090\'f2\u1085\'ed\u1099\'fb\u1085\'ed\u1077\'e5 \u1103\'ff \u1090\'f2\u1077\'e5\u1073\'e1\u1077\'e5 \u1074\'e2\u1088\'f0\u1091\'f3\u1095\'f7\u1072\'e0\u1102\'fe,}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1055\'cf\u1077\'e5\u1088\'f0\u1077\'e5\u1076\'e4 \u1090\'f2\u1086\'ee\u1073\'e1\u1086\'ee\u1102\'fe \u1089\'f1\u1083\'eb\u1077\'e5\u1079\'e7\u1099\'fb \u1083\'eb\u1100\'fc\u1102\'fe,}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1058\'d2\u1074\'e2\u1086\'ee\u1077\'e5\u1081\'e9 \u1079\'e7\u1072\'e0\u1097\'f9\u1080\'e8\u1090\'f2\u1099\'fb \u1091\'f3\u1084\'ec\u1086\'ee\u1083\'eb\u1103\'ff\u1102\'fe\u8230\'85}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1042\'c2\u1086\'ee\u1086\'ee\u1073\'e1\u1088\'f0\u1072\'e0\u1079\'e7\u1080\'e8: \u1103\'ff \u1079\'e7\u1076\'e4\u1077\'e5\u1089\'f1\u1100\'fc \u1086\'ee\u1076\'e4\u1085\'ed\u1072\'e0,}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1053\'cd\u1080\'e8\u1082\'ea\u1090\'f2\u1086\'ee \u1084\'ec\u1077\'e5\u1085\'ed\u1103\'ff \u1085\'ed\u1077\'e5 \u1087\'ef\u1086\'ee\u1085\'ed\u1080\'e8\u1084\'ec\u1072\'e0\u1077\'e5\u1090\'f2,}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
