\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1048\'c8 \u1078\'e6\u1072\'e0\u1088\'f0\u1082\'ea\u1080\'e8\u1081\'e9 \u1086\'ee\u1076\'e4\u1080\'e8\u1085\'ed\u1086\'ee\u1082\'ea\u1080\'e8\u1081\'e9 \u1089\'f1\u1086\'ee\u1085\'ed,}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1042\'c2\u1089\'f1\u1105\'b8 \u1087\'ef\u1086\'ee\u1083\'eb\u1085\'ed\u1086\'ee \u1080\'e8\u1084\'ec; \u1074\'e2\u1089\'f1\u1105\'b8 \u1076\'e4\u1077\'e5\u1074\'e2\u1077\'e5 \u1084\'ec\u1080\'e8\u1083\'eb\u1086\'ee\u1081\'e9}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
\u1041\'c1\u1077\'e5\u1079\'e7 \u1091\'f3\u1084\'ec\u1086\'ee\u1083\'eb\u1082\'ea\u1091\'f3 \u1074\'e2\u1086\'ee\u1083\'eb\u1096\'f8\u1077\'e5\u1073\'e1\u1085\'ed\u1086\'ee\u1081\'e9 \u1089\'f1\u1080\'e8\u1083\'eb\u1086\'ee\u1081\'e9}
\par \pard\plain \s33\ql\li2000\lin2000\ri600\rin600\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af11\afs24\alang1081\ltrch\hich\af5\afs24\alang1049\ai0\ab0\dbch\af9\langfe2052\loch\f5\fs24\lang1049\i0\b0\ql\fi567\li2000\lin2000\ri600\rin600\sb0\sa0\ltrpar{
